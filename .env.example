# Copy to .env and fill in your environment (never commit .env)

# Bastion (local SSH): ssh -i ~/.ssh/bastion.pem ubuntu@<bastion-host>
MCP_JUMP_HOST=ubuntu@<bastion-host>
MCP_SSH_KEY=~/.ssh/bastion.pem

# Optional inner hop from bastion. Leave empty to run AWS/kubectl on the bastion.
# MCP_INNER_HOST=ubuntu@<inner-host>
# MCP_INNER_SSH_KEY=/tmp/inner.pem
MCP_INNER_HOST=
MCP_INNER_SSH_KEY=

# Default CloudWatch log group prefix
MCP_LOG_PREFIX=/eks/prod/default/

# Per remote SSH script timeout (ms)
MCP_EXEC_TIMEOUT_MS=120000

# Max stdout/stderr capture per remote call (bytes)
MCP_MAX_BUFFER=10485760

# Scan tuning
MCP_SCAN_MODE=insights
MCP_SCAN_PARALLEL=16
MCP_INSIGHTS_BATCH_SIZE=50

# Pipeline phase budgets (ms)
MCP_PIPELINE_APP_BUDGET_MS=90000
MCP_PIPELINE_INFRA_BUDGET_MS=30000
MCP_PIPELINE_TOTAL_BUDGET_MS=120000

# Phase 4 output caps
MCP_MAX_OUTPUT_BYTES=51200
MCP_MAX_BLOCKS=10
MCP_MAX_SNIPPET_BYTES=10240

# Service catalog path (legacy fallback when dependency map has no keyword match)
MCP_SERVICE_CATALOG_PATH=./config/service-catalog.json

# Direction Agent dependency map (Phase 1 topology routing)
MCP_DEPENDENCY_MAP_PATH=./config/dependency-map.json

# K8s default namespace for infra phase
MCP_K8S_NAMESPACE=default

# Optional mini synthesis profile (tighter caps)
# MCP_SYNTHESIS_PROFILE=mini

# --- Web chat (v6.1) ---
# Runs minimal web UI + backend API on this port.
WEB_PORT=3000

# Use RAW_PIPELINE to return draftRcaMarkdown directly,
# or OPENAI_SUMMARY to ask OpenAI for conversational formatting.
CHAT_RESPONSE_MODE=OPENAI_SUMMARY

# OpenAI API key for web chat backend only (never exposed to frontend JS).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=15000

# Keep last N turns per session in server memory.
CHAT_MEMORY_TURNS=5
